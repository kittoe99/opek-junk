# OpenAI API Configuration
# For local development (client-side access)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# For production (server-side API routes)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=https://mjgwoukwyqwoectxfwqv.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe (use test keys from https://dashboard.stripe.com/test/apikeys)
# Client-side publishable key (pk_test_... for test mode)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Server-side secret key (sk_test_... for test mode) — never expose to the browser
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
